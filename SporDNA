    <!-- ==================== CORE KINESIOLOGIC EXPERT ENGINE (JAVASCRIPT) ==================== -->
    <script>
        // Form & App states
        let currentStep = 0;
        const totalSteps = 5;
        let activePage = "analiz";
        let currentSlide = 0;
        let currentChapter = 0;
        let themeIsDark = false;
        let historyLogs = [];

        // LOAD LOCAL HISTORY DATABASE
        function loadHistoryFromStorage() {
            try {
                const stored = localStorage.getItem("spordna_history");
                if (stored) {
                    historyLogs = JSON.parse(stored);
                } else {
                    historyLogs = [];
                }
            } catch (err) {
                console.error("Local history empty", err);
                historyLogs = [];
            }
            updateHistoryCounterUI();
            renderHistoryLogs();
        }

        function saveHistoryToStorage() {
            try {
                localStorage.setItem("spordna_history", JSON.stringify(historyLogs));
            } catch (err) {
                console.error("Failed to write to local storage", err);
            }
            updateHistoryCounterUI();
            renderHistoryLogs();
        }

        function updateHistoryCounterUI() {
            const counter = document.getElementById("lbl-history-counter");
            if (counter) {
                counter.innerText = `${historyLogs.length} Başarılı Tarama Saklı`;
            }
        }

        // TAB SWITCHER
        function switchPage(pageId) {
            activePage = pageId;
            document.querySelectorAll(".app-page").forEach(page => {
                page.classList.add("hidden");
            });

            const activeDiv = document.getElementById(`page-${pageId}`);
            if (activeDiv) activeDiv.classList.remove("hidden");

            // Update Breadcrumbs & Header Title contexts
            const bcrumb = document.getElementById("breadcrumb-title");
            const headerTitle = document.getElementById("view-header-title");

            if (pageId === "analiz") {
                bcrumb.innerText = "BİYOMEKANİK KİNESİYOLOJİ LABORATUVARI";
                headerTitle.innerText = "Fiziksel Parametrelerinizi Tanımlayın";
            } else if (pageId === "team") {
                bcrumb.innerText = "PROJE GELİŞTİRİCİ ÇEKİRDEK KADRO";
                headerTitle.innerText = "Geliştirici Takım Üyeleri ve Görevleri";
            } else if (pageId === "report") {
                bcrumb.innerText = "AKADEMİK ANALİZ RAPORU";
                headerTitle.innerText = "Bilimsel Kinesiyolojik Temeller El Kitabı";
                setReportChapter(currentChapter);
            } else if (pageId === "presentation") {
                bcrumb.innerText = "YATIRIMCI SUNUM KABİNİ";
                headerTitle.innerText = "SporDNA Projesi Tanıtım Slaytları";
                renderSlide(currentSlide);
            } else if (pageId === "outputs") {
                bcrumb.innerText = "ANALİZ ARŞİVİ VE BİLİMSEL PAYLAŞIM";
                headerTitle.innerText = "Kişisel Antropometrik Çıktılarınız";
                renderHistoryLogs();
            }

            // Sync menu button active stylings
            document.querySelectorAll(".nav-btn").forEach(btn => {
                btn.classList.add("text-slate-600", "hover:bg-slate-100", "dark:text-slate-300", "dark:hover:bg-slate-800");
                btn.classList.remove("bg-slate-900", "text-white", "dark:bg-emerald-500", "dark:text-slate-950", "font-bold", "shadow-xs");
            });

            const currentBtn = document.getElementById(`nav-${pageId}`);
            if (currentBtn) {
                currentBtn.classList.remove("text-slate-600", "hover:bg-slate-100", "dark:text-slate-300", "dark:hover:bg-slate-800");
                if (themeIsDark) {
                    currentBtn.classList.add("bg-emerald-500", "text-slate-950", "font-bold", "shadow-xs");
                } else {
                    currentBtn.classList.add("bg-slate-900", "text-white", "font-bold", "shadow-xs");
                }
            }

            // Scroll top
            window.scrollTo({ top: 0, behavior: "smooth" });
            lucide.createIcons();
        }

        // AYARLAR AND THEME MANAGER
        function setTheme(isDark) {
            themeIsDark = isDark;
            const htmlEl = document.documentElement;
            const btnLight = document.getElementById("btn-theme-light");
            const btnDark = document.getElementById("btn-theme-dark");

            if (isDark) {
                htmlEl.classList.add("dark");
                localStorage.setItem("spordna_theme", "dark");
                
                // Style triggers
                if (btnDark) {
                    btnDark.className = "py-1.5 text-[10px] font-bold rounded-lg flex items-center justify-center gap-1.5 transition-all outline-none cursor-pointer bg-slate-850 text-emerald-400 border border-slate-800 shadow-3xs";
                }
                if (btnLight) {
                    btnLight.className = "py-1.5 text-[10px] font-bold rounded-lg flex items-center justify-center gap-1.5 transition-all outline-none cursor-pointer text-slate-400 hover:text-slate-200";
                }
            } else {
                htmlEl.classList.remove("dark");
                localStorage.setItem("spordna_theme", "light");

                if (btnLight) {
                    btnLight.className = "py-1.5 text-[10px] font-bold rounded-lg flex items-center justify-center gap-1.5 transition-all outline-none cursor-pointer bg-white text-slate-900 shadow-3xs";
                }
                if (btnDark) {
                    btnDark.className = "py-1.5 text-[10px] font-bold rounded-lg flex items-center justify-center gap-1.5 transition-all outline-none cursor-pointer text-gray-500 hover:text-slate-850";
                }
            }

            // Sync menu btn colors for consistency without page switching
            switchPage(activePage);
        }

        // SETUP ON PAGE INITIAL LOADS
        document.addEventListener("DOMContentLoaded", () => {
            // Read theme key preference
            const savedTheme = localStorage.getItem("spordna_theme");
            if (savedTheme === "dark") {
                setTheme(true);
            } else {
                setTheme(false);
            }
            
            // Read localStorage history
            loadHistoryFromStorage();
            setReportChapter(0);
            renderSlide(0);
            goToStep(0);
            lucide.createIcons();
        });

        // Form answers object initialized with middle values
        const answers = {
            general: { gender: "Erkek", age: 24, height: 180, weight: 75, fitnessLevel: "Orta" },
            skeleton: { shoulderWidth: "Orta", hipWidth: "Orta", limbLengthRatio: "Ortalama", spineAlignment: "Düzgün" },
            posture: { spineCurve: "Normal", shoulderPosition: "Dengeli", pelvisAlignment: "Dengeli" },
            muscle: { bodyType: "Mezomorf", muscleFiberType: "Karışık", flexibility: "Orta" },
            boneAge: { suspectedBoneAge: "Normal", jointMobility: "Normal" },
            goals: { mainGoals: "Sağlıklı Yaşam", injuryHistory: "" }
        };

        // Form setters helpers
        function setGender(val) {
            answers.general.gender = val;
            document.querySelectorAll('.gender-btn').forEach(btn => {
                btn.classList.add('bg-white', 'text-gray-700', 'border-gray-200');
                btn.classList.remove('bg-slate-900', 'text-white', 'border-slate-900', 'shadow-xs');
            });
            const selected = document.getElementById(`btn-gender-${val}`);
            if (selected) {
                selected.classList.remove('bg-white', 'text-gray-700', 'border-gray-200');
                selected.classList.add('bg-slate-900', 'text-white', 'border-slate-900', 'shadow-xs');
            }
        }

        function setFitness(val) {
            answers.general.fitnessLevel = val;
            document.querySelectorAll('.fit-btn').forEach(btn => {
                btn.classList.add('bg-white', 'border-gray-200');
                btn.classList.remove('border-emerald-500', 'bg-emerald-50/25', 'ring-1', 'ring-emerald-500');
                // fix fonts
                const span = btn.querySelector('span:first-child');
                if (span) {
                    span.classList.add('text-slate-800');
                    span.classList.remove('text-emerald-700');
                }
            });
            const selected = document.getElementById(`btn-fit-${val}`);
            if (selected) {
                selected.classList.remove('bg-white', 'border-gray-200');
                selected.classList.add('border-emerald-500', 'bg-emerald-50/25', 'ring-1', 'ring-emerald-500');
                const span = selected.querySelector('span:first-child');
                if (span) {
                    span.classList.remove('text-slate-800');
                    span.classList.add('text-emerald-700');
                }
            }
        }

        function setSkeleton(field, val) {
            answers.skeleton[field] = val;
            document.querySelectorAll(`.skel-${field}-btn`).forEach(btn => {
                btn.classList.add('bg-white', 'border-gray-200', 'text-slate-700');
                btn.classList.remove('bg-slate-900', 'border-slate-900', 'text-white', 'border-emerald-500', 'bg-emerald-50/20', 'text-emerald-800', 'shadow-xs');
            });
            const id = `btn-skel-${field}-${val}`;
            const selected = document.getElementById(id);
            if (selected) {
                if (field === 'limbLengthRatio' || field === 'spineAlignment') {
                    selected.classList.remove('bg-white', 'border-gray-200');
                    selected.classList.add('border-emerald-500', 'bg-emerald-50/20');
                    selected.querySelector('span:first-child').classList.add('text-emerald-800');
                } else {
                    selected.classList.remove('bg-white', 'border-gray-200', 'text-slate-700');
                    selected.classList.add('bg-slate-900', 'border-slate-900', 'text-white', 'shadow-xs');
                }
            }
        }

        function setPosture(field, val) {
            answers.posture[field] = val;
            document.querySelectorAll(`.post-${field === 'spineCurve' ? 'curve' : field === 'shoulderPosition' ? 'sh' : 'pel'}-btn`).forEach(btn => {
                btn.classList.add('bg-white', 'border-gray-200', 'text-slate-700');
                btn.classList.remove('bg-slate-900', 'border-slate-900', 'text-white');
            });
            const sub = field === 'spineCurve' ? 'curve' : field === 'shoulderPosition' ? 'sh' : 'pel';
            const id = `btn-post-${sub}-${val}`;
            const selected = document.getElementById(id);
            if (selected) {
                selected.classList.remove('bg-white', 'border-gray-200', 'text-slate-700');
                selected.classList.add('bg-slate-900', 'border-slate-900', 'text-white');
            }
        }

        function setMuscle(field, val) {
            answers.muscle[field] = val;
            document.querySelectorAll(`.mus-${field === 'bodyType' ? 'bt' : field === 'muscleFiberType' ? 'fiber' : 'flex'}-btn`).forEach(btn => {
                btn.classList.add('bg-white', 'border-gray-200');
