    function selectVisualZone(zone) {
        const c = document.getElementById('visual-details-card');
        c.className = "bg-slate-50 dark:bg-slate-950 rounded-xl p-4 border-l-4 transition-all";
        if (zone==='spine') {
            c.classList.add('border-emerald-500');
            const d = answers.posture.spineCurve==='Normal'?"Fizyolojik omurga simetri korunmuş. Nötral duruş sağlıklı.":
                `${answers.posture.spineCurve} nedeniyle kontrollü destek bantları ve kalça stabilizasyon egzersizleri yapılmalıdır.`;
