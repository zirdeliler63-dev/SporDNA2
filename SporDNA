        // BIOMECHANICAL EXPERT SYSTEM LOGIC (Kinesiology AI Rule Engine)
        let generatedResult = null;
        let selectedReportDay = "Pazartesi";
        let activeSportIndex = 0;

        function generateAnalysisResults() {
            // Apply text areas inputs
            answers.goals.injuryHistory = document.getElementById('input-injury').value.trim() || "Belirtilmemiş";
            answers.boneAge.suspectedBoneAge = document.getElementById('select-bone-age').value;
            answers.boneAge.jointMobility = document.getElementById('select-joint').value;

            // Compute Sport Scores based on biomechanical rules
            const sports = [];
            
            // Branch 1: Swimming & Rowing (Hydro-leverage)
            let swimScore = 55;
            if (answers.skeleton.shoulderWidth === 'Geniş') swimScore += 15;
            if (answers.skeleton.hipWidth === 'Dar') swimScore += 10;
            if (answers.skeleton.limbLengthRatio === 'Uzun') swimScore += 15;
            if (answers.muscle.flexibility === 'Yüksek') swimScore += 10;
            if (answers.muscle.muscleFiberType === 'Tip 1') swimScore += 10;

            sports.push({
                sportName: "Olimpik Yüzme & Kürek",
                matchScore: Math.min(swimScore, 98),
