        // Apply interactive anatomical SVG visual adjustments depending on form inputs
        function renderAnatomicalModifications() {
            const hasLordoz = answers.posture.spineCurve.includes('Lordoz');
            const hasKifoz = answers.posture.spineCurve.includes('Kifoz');
            const hasSkolyoz = answers.posture.spineCurve.includes('Skolyoz');
            const isAsymmetricShoulder = answers.posture.shoulderPosition.includes('Sol') || answers.posture.shoulderPosition.includes('Sağ');
            const isAsymmetricPelvis = answers.posture.pelvisAlignment.includes('Öne') || answers.posture.pelvisAlignment.includes('Arkaya');

            // Set Spine color according to risk
            const spinePath = document.getElementById('svg-spine-path');
            if (hasLordoz) {
                spinePath.setAttribute('d', 'M 100 80 Q 94 130 100 170 T 96 230');
                spinePath.setAttribute('stroke', '#f59e0b'); // Warn
            } else if (hasKifoz) {
                spinePath.setAttribute('d', 'M 100 80 Q 112 130 100 170 T 100 230');
                spinePath.setAttribute('stroke', '#f97316'); // Serious
            } else if (hasSkolyoz) {
                spinePath.setAttribute('d', 'M 100 80 Q 86 130 100 170 T 114 230');
                spinePath.setAttribute('stroke', '#ef4444'); // Critical
            } else {
                spinePath.setAttribute('d', 'M 100 80 L 100 230');
                spinePath.setAttribute('stroke', '#10b981'); // Stabil healthy
            }

            // Shoulders tilt if asymmetric
            const leftJoint = document.getElementById('svg-shoulder-l');
            const rightJoint = document.getElementById('svg-shoulder-r');
            const shoulderPath = document.getElementById('svg-shoulders-path');

            if (answers.posture.shoulderPosition.includes('Sol')) {
                shoulderPath.setAttribute('d', 'M 60 84 L 140 76');
                leftJoint.setAttribute('cy', '84');
                leftJoint.setAttribute('class', 'fill-amber-500');
                rightJoint.setAttribute('cy', '76');
                rightJoint.setAttribute('class', 'fill-emerald-500');
            } else if (answers.posture.shoulderPosition.includes('Sağ')) {
                shoulderPath.setAttribute('d', 'M 60 76 L 140 84');
                leftJoint.setAttribute('cy', '76');
                leftJoint.setAttribute('class', 'fill-emerald-500');
                rightJoint.setAttribute('cy', '84');
                rightJoint.setAttribute('class', 'fill-amber-500');
            } else {
                shoulderPath.setAttribute('d', 'M 60 80 L 140 80');
                leftJoint.setAttribute('cy', '80');
                leftJoint.setAttribute('class', 'fill-emerald-500');
                rightJoint.setAttribute('cy', '80');
                rightJoint.setAttribute('class', 'fill-emerald-500');
            }

            // Pelvic line tilt if anterior tilt
            const pelvisLine = document.getElementById('svg-pelvis-line');
            if (answers.posture.pelvisAlignment.includes('Öne')) {
                pelvisLine.setAttribute('y1', '226');
                pelvisLine.setAttribute('y2', '234');
                pelvisLine.setAttribute('stroke', '#f59e0b');
            } else {
                pelvisLine.setAttribute('y1', '230');
                pelvisLine.setAttribute('y2', '230');
                pelvisLine.setAttribute('stroke', '#10b981');
            }

            // Initial selected region: Spinal
            selectVisualZone('spine');
        }

