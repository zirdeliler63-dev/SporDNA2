                        <span class="px-2 py-0.5 text-[10px] bg-blue-100 text-blue-800 rounded-md font-bold">${answers.skeleton.shoulderWidth} Genişlik</span>
                    </div>
                    <p class="text-xs font-semibold text-slate-700 mt-2 font-mono">Duruş: ${answers.posture.shoulderPosition}</p>
                    <p class="text-xs text-slate-600 mt-1">${shoulderDesc}</p>
                `;
            } else if (zone === 'pelvis') {
                container.classList.add('border-orange-500');
                const pelvisDesc = answers.posture.pelvisAlignment === 'Dengeli'
                    ? "Pelvis (leğen kemiği) nötr düz simetride olup omurga temelini kusursuz şekilde dengelemektedir."
                    : `${answers.posture.pelvisAlignment} (Anterior/Posterior sapma), bel fıtığı oluşumu veya fasyal gerilimi tetikleyebileceğinden hamstring esnetmelerine öncelik verilmiştir.`;

                container.innerHTML = `
                    <div class="flex items-start justify-between">
                        <h5 class="font-bold text-slate-900 text-xs">Pelvik Denge & Sakral Kök</h5>
                        <span class="px-2 py-0.5 text-[10px] bg-orange-100 text-orange-800 rounded-md font-bold">${answers.skeleton.hipWidth} Kalça</span>
                    </div>
                    <p class="text-xs font-semibold text-slate-700 mt-2 font-mono">Kalça Hizası: ${answers.posture.pelvisAlignment}</p>
                    <p class="text-xs text-slate-600 mt-1">${pelvisDesc}</p>
                `;
            } else if (zone === 'limbs') {
                container.classList.add('border-amber-500');
                container.innerHTML = `
                    <div class="flex items-start justify-between">
                        <h5 class="font-bold text-slate-900 text-xs">Ekstremite (Kol/Bacak) Momentum Kaldıraçları</h5>
                        <span class="px-2 py-0.5 text-[10px] bg-amber-100 text-amber-800 rounded-md font-bold">${answers.skeleton.limbLengthRatio}</span>
                    </div>
                    <p class="text-xs text-slate-600 mt-2">
                        • <strong>Kuvvet Mekaniği:</strong> ${answers.skeleton.limbLengthRatio === 'Kısa' 
                            ? 'Ekstremitelerinizin nispeten kısa olması dikey eksende torku artırarak squat ve halter gücünde biyolojik avantaj sağlar.' 
                            : 'Ekstremitelerinizin uzun olması, doğrusal esneklikte ve yüzme esnasındaki hydro-moment kolu genişliğinde büyük avantaj sağlar.'}
                    </p>
                `;
            }
        }

        // Daily schedule workouts changer
        function setScheduleDay(dayName) {
            document.querySelectorAll('.sched-day-btn').forEach(btn => {
                btn.classList.add('text-slate-600', 'hover:bg-slate-200/50');
                btn.classList.remove('bg-slate-900', 'text-white', 'shadow-xs');
            });
            const clickedBtn = document.getElementById(`btn-day-${dayName}`);
            if (clickedBtn) {
                clickedBtn.classList.remove('text-slate-600', 'hover:bg-slate-200/50');
                clickedBtn.classList.add('bg-slate-900', 'text-white', 'shadow-xs');
            }

            const currentDayMeta = generatedResult.developmentProgram.weeklySchedule.find(d => d.day === dayName);
            const titleLabel = document.getElementById('lbl-workout-title');
            const statusLabel = document.getElementById('lbl-workout-status');
            const exContainer = document.getElementById('js-exercises-container');

            if (!currentDayMeta) return;

            titleLabel.textContent = currentDayMeta.title;
            statusLabel.textContent = currentDayMeta.status;

            // Rest day vs active day style adjustment
            if (currentDayMeta.status === 'Dinlenme') {
                statusLabel.className = 'px-2.5 py-0.5 rounded-full text-xs font-bold border bg-slate-100 text-slate-600 border-slate-200';
            } else {
                statusLabel.className = 'px-2.5 py-0.5 rounded-full text-xs font-bold border bg-emerald-50 text-emerald-700 border-emerald-100';
            }

            exContainer.innerHTML = "";
            if (currentDayMeta.exercises && currentDayMeta.exercises.length > 0) {
                currentDayMeta.exercises.forEach(ex => {
                    const row = document.createElement('div');
                    row.className = "bg-white border border-gray-100 rounded-xl p-4 shadow-3xs hover:border-gray-200 transition-all flex flex-col justify-between";
                    row.innerHTML = `
                        <div>
                            <div class="flex items-start justify-between gap-2">
                                <h5 class="font-extrabold text-slate-900 text-xs">${ex.name}</h5>
                                <span class="text-[9px] font-bold px-2 py-0.5 rounded-md bg-amber-50 text-amber-700 border border-amber-100">${ex.intensity} Şiddet</span>
                            </div>
                            <div class="mt-2.5 flex items-center gap-4 text-xs font-mono text-slate-500 bg-slate-50 px-2 py-1.5 rounded-lg border border-slate-100">
                                <div><strong>Set x Tekrar:</strong> ${ex.sets}</div>
                                <div class="w-[1px] h-3 bg-slate-200"></div>
                                <div><strong>Dinlenme:</strong> ${ex.rest}</div>
                            </div>
                            <p class="text-[11px] text-slate-600 mt-2.5 border-l-2 border-slate-300 pl-2 italic leading-relaxed">${ex.instructions}</p>
                        </div>
                    `;
                    exContainer.appendChild(row);
                });
            } else {
                exContainer.innerHTML = `
                    <div class="col-span-2 flex flex-col items-center justify-center p-8 text-center bg-white border border-dashed border-gray-200 rounded-2xl">
                        <span class="text-2xl mb-1">🧘‍♂️</span>
                        <p class="text-sm font-bold text-slate-800">Aktif ve Tam Fizyolojik Toparlanma Günü</p>
                        <p class="text-xs text-slate-500 max-w-sm mt-1">Egzersiz yapılmamalıdır. Kas lif gruplarındaki mikroskopik yırtıkların onarımı ve laktat fasyasının yenilenmesi için tam dinlenme uygulanmalıdır.</p>
                    </div>
                `;
            }
        }

        // Reset application
        function resetApp() {
            // Hide results
            document.getElementById('results-workspace').classList.add('hidden');

            // Show inputs
            document.getElementById('form-container').classList.remove('hidden');
            document.getElementById('sidebar-panel').classList.remove('hidden');
            document.getElementById('intro-card').classList.remove('hidden');

            activeSportIndex = 0;
            goToStep(0);
        }
    </script>
</body>
</html>
