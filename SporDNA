        let bHtml=""; t.bullets.forEach(b => { bHtml+=`<div class="flex items-start gap-3 bg-slate-50 dark:bg-slate-950 p-4 rounded-2xl border border-slate-100 dark:border-slate-800"><div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shrink-0 mt-1.5"></div><p class="text-xs md:text-sm text-slate-700 dark:text-slate-300 leading-relaxed">${b}</p></div>`; });
        if(cc) cc.innerHTML=`<h3 class="text-base md:text-xl font-bold text-slate-900 dark:text-white">${t.title}</h3><div class="space-y-3 mt-4">${bHtml}</div>`;
        if(bc) { bc.innerHTML=""; for(let i=0;i<presentationSlides.length;i++){const d=document.createElement("div");d.className=`w-2 h-2 rounded-full cursor-pointer transition-colors ${i===idx?"bg-emerald-500":"bg-slate-200 dark:bg-slate-700"}`;d.setAttribute("onclick",`renderSlide(${i})`);bc.appendChild(d);} }
    }
    function prevSlide() { renderSlide(currentSlide>0?currentSlide-1:presentationSlides.length-1); }
    function nextSlide() { renderSlide(currentSlide<presentationSlides.length-1?currentSlide+1:0); }

    // ---- INIT ----
    document.addEventListener("DOMContentLoaded", () => {
        const saved = localStorage.getItem("spordna_theme");
        setTheme(saved==="dark");
        loadHistoryFromStorage();
        setReportChapter(0);
        renderSlide(0);
        goToStep(0);
        lucide.createIcons();
    });
</script>
