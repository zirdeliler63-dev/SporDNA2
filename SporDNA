<!DOCTYPE html>
<html lang="tr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sporterra - Atletik Biyomekani ve Spor Yönlendirme Sistemi</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700;800&display=swap" rel="stylesheet">
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons CDN -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    boxShadow: {
                        '3xs': '0 1px 2px rgba(0,0,0,0.03)',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @media print {
            .no-print {
                display: none !important;
            }
            .print-card {
                border: none !important;
                box-shadow: none !important;
                padding: 0 !important;
            }
        }
    </style>
</head>
<body class="text-slate-900 selection:bg-emerald-500 selection:text-white flex flex-col min-h-screen">

    <!-- HEADER -->
    <header class="border-b border-gray-100 bg-white sticky top-0 z-50 no-print">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <div class="w-10 h-10 rounded-xl bg-slate-900 flex items-center justify-center">
                    <i data-lucide="trophy" class="w-5 h-5 text-emerald-400"></i>
                </div>
                <div>
                    <h1 class="text-sm font-extrabold text-slate-900 tracking-tight leading-none flex items-center gap-1.5">
                        SPORTERRA <span class="text-[10px] bg-slate-100 text-slate-700 px-1.5 py-0.5 rounded-sm font-normal">KİNESİYOLOJİ</span>
                    </h1>
                    <p class="text-[11px] text-slate-400 leading-none mt-1">
                        Biyomekanik & Postür Odaklı Spor Gelişim Sistemi
                    </p>
                </div>
            </div>

            <div class="hidden md:flex items-center gap-6 text-xs text-slate-500 font-medium">
                <span class="flex items-center gap-1.5">
                    <i data-lucide="shield-check" class="w-4 h-4 text-emerald-500"></i> %100 Bilimsel Analiz
                </span>
                <span class="flex items-center gap-1.5">
                    <i data-lucide="zap" class="w-4 h-4 text-amber-500 animate-pulse"></i> Yerel Kinesiyoloji Motoru
                </span>
            </div>
        </div>
    </header>

    <!-- CONTENT WRAPPER -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-1 w-full">
        
        <!-- INITIAL MARKETING BAR -->
        <div id="intro-card" class="mb-8 p-6 bg-white border border-gray-100 rounded-3xl flex flex-col md:flex-row items-start md:items-center justify-between gap-6 no-print">
            <div class="max-w-2xl">
                <h2 class="text-xl md:text-2xl font-black text-slate-900 tracking-tight leading-snug">
                     Fiziksel Özelliklerinize %100 Uyan Spor Branşını Tespit Edin
                </h2>
                <p class="text-xs text-slate-500 leading-relaxed mt-1">
                    Bu sistem iskelet yapınızı (omuz/kalça oranı), duruş sapmalarını (kifoz, lordoz, asimetriler), kas lifi yapınızı ve eklem mobilitenizi sentezleyerek size yön vermeyi amaçlar. Formu doldurarak veya örnek atlet profillerini kullanarak test edebilirsiniz.
                </p>
            </div>

            <!-- Live Status label -->
            <div class="bg-slate-50 border border-slate-100 rounded-2xl p-4 shrink-0 flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center">
                    <i data-lucide="activity" class="w-4 h-4 text-emerald-600 animate-pulse"></i>
                </div>
                <div>
                    <div class="text-xs font-bold text-slate-800">Doğru Yönlendirme</div>
                    <div class="text-[10px] text-gray-400 leading-none mt-0.5">Momentum & Biyomekanik katsayı tespiti</div>
                </div>
            </div>
        </div>

        <!-- MAIN GRID: FORM OR RESULTS -->
        <div id="app-workspace" class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            
            <!-- LEFT WIZARD BOX -->
            <div id="form-container" class="lg:col-span-3 bg-white border border-gray-100 rounded-3xl p-6 md:p-8 shadow-sm no-print">
                
                <!-- Stepper Progress bar -->
                <div class="relative mb-8">
                    <div class="flex justify-between items-center relative z-10">
                        <!-- Step 1 -->
                        <div class="flex flex-col items-center cursor-pointer step-indicator" onclick="goToStep(0)">
                            <div id="step-badge-0" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xs border transition-all duration-300 bg-slate-900 border-slate-900 text-white shadow-md ring-4 ring-slate-100">1</div>
                            <span id="step-text-0" class="text-[10px] sm:text-[11px] font-bold text-slate-900 mt-2">Genel Bilgiler</span>
                        </div>
                        <!-- Step 2 -->
                        <div class="flex flex-col items-center cursor-pointer step-indicator" onclick="goToStep(1)">
                            <div id="step-badge-1" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xs border transition-all duration-300 bg-white border-gray-200 text-gray-400">2</div>
                            <span id="step-text-1" class="text-[10px] sm:text-[11px] font-medium text-gray-400 mt-2">İskelet Yapısı</span>
                        </div>
                        <!-- Step 3 -->
                        <div class="flex flex-col items-center cursor-pointer step-indicator" onclick="goToStep(2)">
                            <div id="step-badge-2" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xs border transition-all duration-300 bg-white border-gray-200 text-gray-400">3</div>
                            <span id="step-text-2" class="text-[10px] sm:text-[11px] font-medium text-gray-400 mt-2">Duruş (Postür)</span>
                        </div>
                        <!-- Step 4 -->
                        <div class="flex flex-col items-center cursor-pointer step-indicator" onclick="goToStep(3)">
                            <div id="step-badge-3" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xs border transition-all duration-300 bg-white border-gray-200 text-gray-400">4</div>
                            <span id="step-text-3" class="text-[10px] sm:text-[11px] font-medium text-gray-400 mt-2">Kas & Lif Tipi</span>
                        </div>
                        <!-- Step 5 -->
                        <div class="flex flex-col items-center cursor-pointer step-indicator" onclick="goToStep(4)">
                            <div id="step-badge-4" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xs border transition-all duration-300 bg-white border-gray-200 text-gray-400">5</div>
                            <span id="step-text-4" class="text-[10px] sm:text-[11px] font-medium text-gray-400 mt-2">Kemik & Hedef</span>
                        </div>
                    </div>
                    <!-- Indicator line line -->
                    <div class="absolute top-[18px] left-[6%] right-[6%] h-[2px] bg-slate-100 -z-10">
                        <div id="stepper-line" class="h-full bg-emerald-500 transition-all duration-500 w-0"></div>
                    </div>
                </div>

                <!-- Validation Warning Alert -->
                <div id="validation-alert" class="hidden mb-6 p-4 bg-red-50 border-l-4 border-red-500 rounded-xl flex items-center gap-3 text-red-700 text-xs font-medium">
                    <i data-lucide="alert-circle" class="w-5 h-5 text-red-500 shrink-0"></i>
                    <span id="validation-msg">Lütfen eksik alanları doldurunuz.</span>
                </div>

                <!-- FORM CONTENT SECTIONS -->
                <form id="kinesiology-form" class="min-h-[290px]">
                    
                    <!-- STEP 0: GENERAL SYSTEM INPUTS -->
                    <div id="form-step-0" class="step-pane space-y-6">
                        <div class="border-b border-gray-100 pb-2">
                            <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
                                <i data-lucide="user" class="w-5 h-5 text-emerald-500"></i> Temel Fiziksel Parametreler
                            </h3>
                            <p class="text-[11px] text-slate-500">
                                Genel antropometrik yapınızı girin. Bu değerler mekanik direnç hesabı için temel teşkil eder.
                            </p>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Yaş (Yıl)</label>
                                <input type="number" id="input-age" value="24" min="5" max="100" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-slate-800 outline-none text-sm bg-slate-50/50" />
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Boy (cm)</label>
                                <input type="number" id="input-height" value="180" min="100" max="230" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-slate-800 outline-none text-sm bg-slate-50/50" />
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Kilo (kg)</label>
                                <input type="number" id="input-weight" value="75" min="25" max="200" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-slate-800 outline-none text-sm bg-slate-50/50" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-3">Biyolojik Cinsiyet</label>
                            <div class="grid grid-cols-3 gap-3">
                                <button type="button" onclick="setGender('Erkek')" id="btn-gender-Erkek" class="gender-btn px-4 py-3 border text-xs font-semibold rounded-xl text-center transition-all bg-slate-900 border-slate-900 text-white shadow-xs">Erkek</button>
                                <button type="button" onclick="setGender('Kadın')" id="btn-gender-Kadın" class="gender-btn px-4 py-3 border text-xs font-semibold rounded-xl text-center transition-all bg-white border-gray-200 text-gray-700 hover:bg-slate-50">Kadın</button>
                                <button type="button" onclick="setGender('Belirtmek İstemiyorum')" id="btn-gender-Belirtmek İstemiyorum" class="gender-btn px-4 py-3 border text-xs font-semibold rounded-xl text-center transition-all bg-white border-gray-200 text-gray-700 hover:bg-slate-50">Belirtmek İstemiyorum</button>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-3">Güncel Spor Seviyesi</label>
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                                <button type="button" onclick="setFitness('Başlangıç')" id="btn-fit-Başlangıç" class="fit-btn p-4 border text-left rounded-2xl transition-all flex flex-col gap-1 bg-white border-gray-200 hover:bg-slate-50/50">
                                    <span class="text-xs font-bold text-slate-800">Başlangıç Seviyesi</span>
                                    <span class="text-[10px] text-gray-500 leading-snug">Haftada en fazla 1 gün veya hiç spor yapmıyor.</span>
                                </button>
                                <button type="button" onclick="setFitness('Orta')" id="btn-fit-Orta" class="fit-btn p-4 border text-left rounded-2xl transition-all flex flex-col gap-1 border-emerald-500 bg-emerald-50/25 ring-1 ring-emerald-500">
                                    <span class="text-xs font-bold text-emerald-700">Orta Seviye</span>
                                    <span class="text-[10px] text-gray-500 leading-snug">Haftada 2-3 gün düzenli egzersiz veya rekreasyonel spor geçmişi.</span>
                                </button>
                                <button type="button" onclick="setFitness('İleri')" id="btn-fit-İleri" class="fit-btn p-4 border text-left rounded-2xl transition-all flex flex-col gap-1 bg-white border-gray-200 hover:bg-slate-50/50">
                                    <span class="text-xs font-bold text-slate-800">İleri / Profesyonel</span>
                                    <span class="text-[10px] text-gray-500 leading-snug">Haftada 4 günden fazla direnç ve kondisyon çalışan lisanslı sporcu.</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- STEP 1: SKELETAL INPUTS -->
                    <div id="form-step-1" class="step-pane hidden space-y-6">
                        <div class="border-b border-gray-100 pb-2">
                            <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
                                <i data-lucide="compass" class="w-5 h-5 text-emerald-500"></i> İskelet Yapısı & Kemik Çatısı
                            </h3>
                            <p class="text-[11px] text-slate-500">
                                Omuz-kalça oranları ve ekstremite uzunlukları, kuvvet momentini ve spor biyomekaniğini doğrudan etkiler.
                            </p>
                        </div>

                        <div class="space-y-5">
                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Omuz Genişliği</label>
                                <div class="grid grid-cols-3 gap-3">
                                    <button type="button" onclick="setSkeleton('shoulderWidth', 'Dar')" id="btn-skel-shoulder-Dar" class="skel-shoulder-btn py-3 px-4 border text-xs font-bold rounded-xl bg-white border-gray-200 hover:bg-slate-50">Dar omuzlar</button>
                                    <button type="button" onclick="setSkeleton('shoulderWidth', 'Orta')" id="btn-skel-shoulder-Orta" class="skel-shoulder-btn py-3 px-4 border text-xs font-bold rounded-xl bg-slate-900 border-slate-900 text-white shadow-xs">Orta omuzlar</button>
                                    <button type="button" onclick="setSkeleton('shoulderWidth', 'Geniş')" id="btn-skel-shoulder-Geniş" class="skel-shoulder-btn py-3 px-4 border text-xs font-bold rounded-xl bg-white border-gray-200 hover:bg-slate-50">Geniş omuzlar</button>
                                </div>
                            </div>

                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Kalça Genişliği</label>
                                <div class="grid grid-cols-3 gap-3">
                                    <button type="button" onclick="setSkeleton('hipWidth', 'Dar')" id="btn-skel-hip-Dar" class="skel-hip-btn py-3 px-4 border text-xs font-bold rounded-xl bg-white border-gray-200 hover:bg-slate-50">Dar kalça</button>
                                    <button type="button" onclick="setSkeleton('hipWidth', 'Orta')" id="btn-skel-hip-Orta" class="skel-hip-btn py-3 px-4 border text-xs font-bold rounded-xl bg-slate-900 border-slate-900 text-white shadow-xs">Orta kalça</button>
                                    <button type="button" onclick="setSkeleton('hipWidth', 'Geniş')" id="btn-skel-hip-Geniş" class="skel-hip-btn py-3 px-4 border text-xs font-bold rounded-xl bg-white border-gray-200 hover:bg-slate-50">Geniş kalça</button>
                                </div>
                            </div>

                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Gövdeye Oranla Kol & Bacak (Ekstremite) Uzunluğu</label>
                                <div class="grid grid-cols-3 gap-3">
                                    <button type="button" onclick="setSkeleton('limbLengthRatio', 'Kısa')" id="btn-skel-limb-Kısa" class="skel-limb-btn p-3 border text-left rounded-xl flex flex-col gap-1 bg-white border-gray-200 hover:bg-slate-50">
                                        <span class="text-xs font-bold text-slate-800">Kısa Kollar/Bacaklar</span>
                                        <span class="text-[9px] text-gray-500 leading-tight">Yüksek tork ve kaldırma momenti avantajı.</span>
                                    </button>
                                    <button type="button" onclick="setSkeleton('limbLengthRatio', 'Ortalama')" id="btn-skel-limb-Ortalama" class="skel-limb-btn p-3 border text-left rounded-xl flex flex-col gap-1 border-emerald-500 bg-emerald-50/20">
                                        <span class="text-xs font-bold text-emerald-800">Dengeli Limbler</span>
                                        <span class="text-[9px] text-gray-400 leading-tight">Çok yönlü standart koordinasyon düzeyi.</span>
                                    </button>
                                    <button type="button" onclick="setSkeleton('limbLengthRatio', 'Uzun')" id="btn-skel-limb-Uzun" class="skel-limb-btn p-3 border text-left rounded-xl flex flex-col gap-1 bg-white border-gray-200 hover:bg-slate-50">
                                        <span class="text-xs font-bold text-slate-800">Uzun Kollar/Bacaklar</span>
                                        <span class="text-[9px] text-gray-500 leading-tight">Yüzme kulaç mesafesi ve kaldıraç genişliği.</span>
                                    </button>
                                </div>
                            </div>

                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Simetrik Omurga Dizilimi</label>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                    <button type="button" onclick="setSkeleton('spineAlignment', 'Düzgün')" id="btn-skel-spinealign-Düzgün" class="skel-spinealign-btn p-3 border text-left rounded-xl flex flex-col gap-1 border-emerald-500 bg-emerald-50/20">
                                        <span class="text-xs font-bold text-emerald-800">Düzgün ve Eksenel Dengeli</span>
                                        <span class="text-[9px] text-gray-500 leading-tight">Ayakta dururken iki taraflı omuzlar yatay hizada.</span>
                                    </button>
                                    <button type="button" onclick="setSkeleton('spineAlignment', 'Asimetri Şüphesi')" id="btn-skel-spinealign-Asimetri Şüphesi" class="skel-spinealign-btn p-3 border text-left rounded-xl flex flex-col gap-1 bg-white border-gray-200 hover:bg-slate-50">
                                        <span class="text-xs font-bold text-slate-800">Hafif Asimetri Şüphesi</span>
                                        <span class="text-[9px] text-gray-500 leading-tight">Kürek kemiklerinin bir tarafı hafif daha çıkık veya eğik görünümde.</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- STEP 2: POSTURE INPUTS -->
                    <div id="form-step-2" class="step-pane hidden space-y-6">
                        <div class="border-b border-gray-100 pb-2">
                            <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
                                <i data-lucide="activity" class="w-5 h-5 text-emerald-500"></i> Duruş (Postür) Yapısı
                            </h3>
                            <p class="text-[11px] text-slate-500">
                                Vücut postür haritanız, spor dallarındaki fıtık veya omurga risklerini azaltan en önemli göstergedir.
                            </p>
                        </div>

                        <div class="space-y-4">
                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Yandan Bakışta Sırt/Bel Kavisi</label>
                                <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
                                    <button type="button" onclick="setPosture('spineCurve', 'Normal')" id="btn-post-curve-Normal" class="post-curve-btn p-3 border text-left text-xs font-bold rounded-xl bg-slate-900 border-slate-900 text-white">Normal Kavis</button>
                                    <button type="button" onclick="setPosture('spineCurve', 'Lordoz')" id="btn-post-curve-Lordoz" class="post-curve-btn p-3 border text-left text-xs font-bold rounded-xl bg-white border-gray-200 text-slate-700 hover:bg-slate-50">Lordoz (Çukur Bel)</button>
                                    <button type="button" onclick="setPosture('spineCurve', 'Kifoz')" id="btn-post-curve-Kifoz" class="post-curve-btn p-3 border text-left text-xs font-bold rounded-xl bg-white border-gray-200 text-slate-700 hover:bg-slate-50">Kifoz (Kamburluk)</button>
                                    <button type="button" onclick="setPosture('spineCurve', 'Skolyoz')" id="btn-post-curve-Skolyoz" class="post-curve-btn p-3 border text-left text-xs font-bold rounded-xl bg-white border-gray-200 text-slate-700 hover:bg-slate-50">Yanal Eğrilik (Skolyoz)</button>
                                </div>
                            </div>

                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Omuz Başlarının Konumu</label>
                                <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
                                    <button type="button" onclick="setPosture('shoulderPosition', 'Dengeli')" id="btn-post-sh-Dengeli" class="post-sh-btn p-3 border text-left text-xs font-bold rounded-xl bg-slate-900 border-slate-900 text-white">Dengeli / Doğal</button>
                                    <button type="button" onclick="setPosture('shoulderPosition', 'Sol Düşük')" id="btn-post-sh-Sol Düşük" class="post-sh-btn p-3 border text-left text-xs font-bold rounded-xl bg-white border-gray-200 text-slate-700 hover:bg-slate-50">Sol Omuz Düşük</button>
                                    <button type="button" onclick="setPosture('shoulderPosition', 'Sağ Düşük')" id="btn-post-sh-Sağ Düşük" class="post-sh-btn p-3 border text-left text-xs font-bold rounded-xl bg-white border-gray-200 text-slate-700 hover:bg-slate-50">Sağ Omuz Düşük</button>
                                    <button type="button" onclick="setPosture('shoulderPosition', 'Öne Çökük')" id="btn-post-sh-Öne Çökük" class="post-sh-btn p-3 border text-left text-xs font-bold rounded-xl bg-white border-gray-200 text-slate-700 hover:bg-slate-50">Öne Yuvarlanmış</button>
                                </div>
                            </div>

                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Kalça (Pelvis) Hizası</label>
                                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                                    <button type="button" onclick="setPosture('pelvisAlignment', 'Dengeli')" id="btn-post-pel-Dengeli" class="post-pel-btn p-3 border text-left text-xs font-bold rounded-xl bg-slate-900 border-slate-900 text-white">Dengeli Nötr</button>
                                    <button type="button" onclick="setPosture('pelvisAlignment', 'Öne Eğik')" id="btn-post-pel-Öne Eğik" class="post-pel-btn p-3 border text-left text-xs font-bold rounded-xl bg-white border-gray-200 text-slate-700 hover:bg-slate-50">Anterior Tilt (Öne Eğik)</button>
                                    <button type="button" onclick="setPosture('pelvisAlignment', 'Arkaya Eğik')" id="btn-post-pel-Arkaya Eğik" class="post-pel-btn p-3 border text-left text-xs font-bold rounded-xl bg-white border-gray-200 text-slate-700 hover:bg-slate-50">Posterior Tilt (Düz Bel)</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- STEP 3: MUSCLE PATHOLOGY -->
                    <div id="form-step-3" class="step-pane hidden space-y-6">
                        <div class="border-b border-gray-100 pb-2">
