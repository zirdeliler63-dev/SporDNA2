                setFitness('İleri');
                setSkeleton('shoulderWidth', 'Geniş');
                setSkeleton('hipWidth', 'Geniş');
                setSkeleton('limbLengthRatio', 'Kısa');
                setSkeleton('spineAlignment', 'Düzgün');
                setPosture('spineCurve', 'Lordoz');
