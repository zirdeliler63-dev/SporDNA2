    function renderCharts() {
        if (!generatedResult) return;
        // Bar chart
        const barCtx = document.getElementById('chart-sports-bar');
        if (barCtx) {
            if (chartSports) chartSports.destroy();
            chartSports = new Chart(barCtx, {
                type: 'bar',
                data: {
                    labels: generatedResult.recommendedSports.map(s => s.sportName.split(' & ')[0]),
                    datasets: [{
                        label: 'Uyumluluk (%)',
                        data: generatedResult.recommendedSports.map(s => s.matchScore),
                        backgroundColor: ['rgba(16,185,129,0.85)','rgba(99,102,241,0.85)','rgba(245,158,11,0.85)'],
                        borderRadius: 8, borderSkipped: false
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { min: 0, max: 100, ticks: { font: { size: 10 } } }, x: { ticks: { font: { size: 9 } } } } }
            });
        }
        // Radar chart
        const radCtx = document.getElementById('chart-body-radar');
        if (radCtx) {
            if (chartRadar) chartRadar.destroy();
            const flexScore = answers.muscle.flexibility==='Yüksek'?90:answers.muscle.flexibility==='Orta'?60:35;
            const strScore = answers.muscle.muscleFiberType==='Tip 2'?85:answers.muscle.muscleFiberType==='Karışık'?65:45;
            const skelScore = answers.skeleton.shoulderWidth==='Geniş'?85:answers.skeleton.shoulderWidth==='Orta'?65:45;
            const postScore = answers.posture.spineCurve==='Normal'?90:60;
            const fitScore = answers.general.fitnessLevel==='İleri'?90:answers.general.fitnessLevel==='Orta'?65:40;
            chartRadar = new Chart(radCtx, {
                type: 'radar',
                data: {
                    labels: ['Esneklik','Patlayıcı Güç','İskelet','Postür','Kondisyon'],
                    datasets: [{ label: 'Biyomekanik Profil', data: [flexScore,strScore,skelScore,postScore,fitScore],
                        backgroundColor: 'rgba(16,185,129,0.18)', borderColor: '#10b981', borderWidth: 2, pointBackgroundColor: '#10b981', pointRadius: 4 }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { r: { min: 0, max: 100, ticks: { font: { size: 9 }, stepSize: 25 } } } }
            });
        }
