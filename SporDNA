    function renderAnatomicalModifications() {
        const hasLordoz = answers.posture.spineCurve.includes('Lordoz');
        const hasKifoz = answers.posture.spineCurve.includes('Kifoz');
        const hasSkolyoz = answers.posture.spineCurve.includes('Skolyoz');

        const spinePath = document.getElementById('svg-spine-path');
        if (spinePath) {
            if (hasLordoz) { spinePath.setAttribute('d','M 100 80 Q 94 130 100 170 T 96 230'); spinePath.setAttribute('stroke','#f59e0b'); }
            else if (hasKifoz) { spinePath.setAttribute('d','M 100 80 Q 112 130 100 170 T 100 230'); spinePath.setAttribute('stroke','#f97316'); }
            else if (hasSkolyoz) { spinePath.setAttribute('d','M 100 80 Q 86 130 100 170 T 114 230'); spinePath.setAttribute('stroke','#ef4444'); }
            else { spinePath.setAttribute('d','M 100 80 L 100 230'); spinePath.setAttribute('stroke','#10b981'); }
        }

        const lj = document.getElementById('svg-shoulder-l'); const rj = document.getElementById('svg-shoulder-r'); const sp = document.getElementById('svg-shoulders-path');
        if (answers.posture.shoulderPosition.includes('Sol')) { if(sp)sp.setAttribute('d','M 60 84 L 140 76'); if(lj){lj.setAttribute('cy','84');lj.setAttribute('class','fill-amber-500');} if(rj){rj.setAttribute('cy','76');rj.setAttribute('class','fill-emerald-500');} }
        else if (answers.posture.shoulderPosition.includes('Sağ')) { if(sp)sp.setAttribute('d','M 60 76 L 140 84'); if(lj){lj.setAttribute('cy','76');lj.setAttribute('class','fill-emerald-500');} if(rj){rj.setAttribute('cy','84');rj.setAttribute('class','fill-amber-500');} }
        else { if(sp)sp.setAttribute('d','M 60 80 L 140 80'); if(lj){lj.setAttribute('cy','80');lj.setAttribute('class','fill-indigo-500');} if(rj){rj.setAttribute('cy','80');rj.setAttribute('class','fill-indigo-500');} }

        const pl = document.getElementById('svg-pelvis-line');
        if (pl) { if(answers.posture.pelvisAlignment.includes('Öne')){pl.setAttribute('y1','226');pl.setAttribute('y2','234');pl.setAttribute('stroke','#f59e0b');}else{pl.setAttribute('y1','230');pl.setAttribute('y2','230');pl.setAttribute('stroke','#10b981');} }

        const lbl_s = document.getElementById('lbl-somatotip'); const lbl_e = document.getElementById('lbl-esneklik');
        if(lbl_s)lbl_s.textContent=answers.muscle.bodyType; if(lbl_e)lbl_e.textContent=answers.muscle.flexibility;

