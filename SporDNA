                setSkeleton('limbLengthRatio', 'Ortalama');
                setSkeleton('spineAlignment', 'Düzgün');
                setPosture('spineCurve', 'Kifoz');
                setPosture('shoulderPosition', 'Öne Çökük');
                setPosture('pelvisAlignment', 'Dengeli');
                setMuscle('bodyType', 'Ektomorf');
                setMuscle('muscleFiberType', 'Karışık');
                setMuscle('flexibility', 'Düşük');
                document.getElementById('select-bone-age').value = "Normal";
                document.getElementById('select-joint').value = "Normal";
                setGoal('Sağlıklı Yaşam');
                document.getElementById('input-injury').value = "Masa başında uzun oturmaktan kaynaklı sırt ve boyun ağrıları.";
            }
            goToStep(0);
