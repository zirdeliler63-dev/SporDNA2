                selected.classList.remove('bg-white', 'text-gray-700', 'border-gray-200');
                selected.classList.add('bg-slate-900', 'text-white', 'border-slate-900', 'shadow-xs');
            }
        }

        function setFitness(val) {
            answers.general.fitnessLevel = val;
            document.querySelectorAll('.fit-btn').forEach(btn => {
                btn.classList.add('bg-white', 'border-gray-200');
                btn.classList.remove('border-emerald-500', 'bg-emerald-50/25', 'ring-1', 'ring-emerald-500');
                // fix fonts
                const span = btn.querySelector('span:first-child');
                if (span) {
                    span.classList.add('text-slate-800');
                    span.classList.remove('text-emerald-700');
                }
            });
            const selected = document.getElementById(`btn-fit-${val}`);
            if (selected) {
                selected.classList.remove('bg-white', 'border-gray-200');
                selected.classList.add('border-emerald-500', 'bg-emerald-50/25', 'ring-1', 'ring-emerald-500');
                const span = selected.querySelector('span:first-child');
                if (span) {
                    span.classList.remove('text-slate-800');
                    span.classList.add('text-emerald-700');
                }
            }
        }

        function setSkeleton(field, val) {
            answers.skeleton[field] = val;
            document.querySelectorAll(`.skel-${field}-btn`).forEach(btn => {
                btn.classList.add('bg-white', 'border-gray-200', 'text-slate-700');
                btn.classList.remove('bg-slate-900', 'border-slate-900', 'text-white', 'border-emerald-500', 'bg-emerald-50/20', 'text-emerald-800', 'shadow-xs');
            });
            const id = `btn-skel-${field}-${val}`;
            const selected = document.getElementById(id);
            if (selected) {
                if (field === 'limbLengthRatio' || field === 'spineAlignment') {
                    selected.classList.remove('bg-white', 'border-gray-200');
                    selected.classList.add('border-emerald-500', 'bg-emerald-50/20');
                    selected.querySelector('span:first-child').classList.add('text-emerald-800');
                } else {
                    selected.classList.remove('bg-white', 'border-gray-200', 'text-slate-700');
                    selected.classList.add('bg-slate-900', 'border-slate-900', 'text-white', 'shadow-xs');
                }
            }
        }

        function setPosture(field, val) {
            answers.posture[field] = val;
            document.querySelectorAll(`.post-${field === 'spineCurve' ? 'curve' : field === 'shoulderPosition' ? 'sh' : 'pel'}-btn`).forEach(btn => {
                btn.classList.add('bg-white', 'border-gray-200', 'text-slate-700');
                btn.classList.remove('bg-slate-900', 'border-slate-900', 'text-white');
            });
            const sub = field === 'spineCurve' ? 'curve' : field === 'shoulderPosition' ? 'sh' : 'pel';
            const id = `btn-post-${sub}-${val}`;
            const selected = document.getElementById(id);
            if (selected) {
                selected.classList.remove('bg-white', 'border-gray-200', 'text-slate-700');
                selected.classList.add('bg-slate-900', 'border-slate-900', 'text-white');
            }
        }

        function setMuscle(field, val) {
            answers.muscle[field] = val;
            document.querySelectorAll(`.mus-${field === 'bodyType' ? 'bt' : field === 'muscleFiberType' ? 'fiber' : 'flex'}-btn`).forEach(btn => {
                btn.classList.add('bg-white', 'border-gray-200');
                // For flexible buttons removing color classes
                btn.classList.remove('border-emerald-500', 'bg-emerald-50/20', 'ring-1', 'ring-emerald-500', 'bg-slate-900', 'border-slate-900', 'text-white', 'shadow-xs');
                const head = btn.querySelector('span:first-child');
                if (head) {
                    head.classList.add('text-slate-800');
                    head.classList.remove('text-emerald-800');
                }
            });
            const sub = field === 'bodyType' ? 'bt' : field === 'muscleFiberType' ? 'fiber' : 'flex';
            const id = `btn-mus-${sub}-${val}`;
            const selected = document.getElementById(id);
            if (selected) {
                if (field === 'flexibility') {
                    selected.classList.remove('bg-white', 'border-gray-200');
                    selected.classList.add('bg-slate-900', 'border-slate-900', 'text-white', 'shadow-xs');
                } else {
                    selected.classList.remove('bg-white', 'border-gray-200');
                    selected.classList.add('border-emerald-500', 'bg-emerald-50/20', 'ring-1', 'ring-emerald-500');
                    const head = selected.querySelector('span:first-child');
                    if (head) {
                        head.classList.remove('text-slate-800');
                        head.classList.add('text-emerald-800');
                    }
                }
            }
        }

        function setGoal(val) {
            answers.goals.mainGoals = val;
            document.querySelectorAll('.goal-btn').forEach(btn => {
                btn.classList.add('bg-white', 'border-gray-200');
                btn.classList.remove('border-emerald-500', 'bg-emerald-50/20', 'text-emerald-800');
            });
            const selected = document.getElementById(`btn-goal-${val}`);
            if (selected) {
                selected.classList.remove('bg-white', 'border-gray-200');
                selected.classList.add('border-emerald-500', 'bg-emerald-50/20', 'text-emerald-800');
            }
        }

        // Stepper mechanics
        function goToStep(idx) {
            // Hide all steps
            for (let i = 0; i < totalSteps; i++) {
                const pane = document.getElementById(`form-step-${i}`);
                if (pane) pane.classList.add('hidden');
                
                // Reset step badge designs
                const badge = document.getElementById(`step-badge-${i}`);
                if (badge) {
                    badge.classList.remove('bg-slate-900', 'border-slate-900', 'text-white', 'shadow-md', 'ring-4', 'ring-slate-100', 'bg-emerald-500', 'border-emerald-500');
                    badge.classList.add('bg-white', 'border-gray-200', 'text-gray-400');
                }
                const label = document.getElementById(`step-text-${i}`);
                if (label) {
                    label.classList.remove('text-slate-900', 'font-bold');
                    label.classList.add('text-gray-400', 'font-medium');
                }
            }

            // Show active step
            const activePane = document.getElementById(`form-step-${idx}`);
            if (activePane) activePane.classList.remove('hidden');

            // Style active badge
            const activeBadge = document.getElementById(`step-badge-${idx}`);
            if (activeBadge) {
                activeBadge.classList.remove('bg-white', 'border-gray-200', 'text-gray-400');
                activeBadge.classList.add('bg-slate-900', 'border-slate-900', 'text-white', 'shadow-md', 'ring-4', 'ring-slate-100');
            }
            const activeLabel = document.getElementById(`step-text-${idx}`);
            if (activeLabel) {
                activeLabel.classList.remove('text-gray-400', 'font-medium');
                activeLabel.classList.add('text-slate-900', 'font-bold');
            }

            // Style completed steps up to idx
            for (let k = 0; k < idx; k++) {
                const checkedBadge = document.getElementById(`step-badge-${k}`);
                if (checkedBadge) {
                    checkedBadge.classList.add('bg-emerald-500', 'border-emerald-500', 'text-white');
                }
            }

            currentStep = idx;

            // Handle bottom buttons states
            const prevBtn = document.getElementById('btn-prev');
            const nextBtn = document.getElementById('btn-next');
            
            if (idx === 0) {
                prevBtn.setAttribute('disabled', 'true');
                prevBtn.classList.add('opacity-40', 'cursor-not-allowed');
            } else {
                prevBtn.removeAttribute('disabled');
                prevBtn.classList.remove('opacity-40', 'cursor-not-allowed');
            }

            if (idx === totalSteps - 1) {
                nextBtn.innerHTML = `<span>HESAPLA & SPOR BUL!</span> <i data-lucide="flame" class="w-4 h-4 text-orange-400 animate-pulse"></i>`;
            } else {
                nextBtn.innerHTML = `<span>İlerle</span> <i data-lucide="chevron-right" class="w-4 h-4"></i>`;
            }
            
            // Adjust step line width
            const line = document.getElementById('stepper-line');
            if (line) {
                line.style.width = `${(idx / (totalSteps - 1)) * 100}%`;
            }

            // Refresh lucide icons
            lucide.createIcons();
            document.getElementById('validation-alert').classList.add('hidden');
        }

        function validateCurrentStep() {
            if (currentStep === 0) {
                const age = parseInt(document.getElementById('input-age').value);
                const height = parseInt(document.getElementById('input-height').value);
                const weight = parseInt(document.getElementById('input-weight').value);

                if (isNaN(age) || age < 5 || age > 100) {
                    showError("Geçerli bir yaş giriniz (5-100).");
                    return false;
                }
                if (isNaN(height) || height < 100 || height > 230) {
                    showError("Geçerli bir boy giriniz (100cm - 230cm).");
                    return false;
                }
                if (isNaN(weight) || weight < 25 || weight > 200) {
                    showError("Geçerli bir ağırlık değeri giriniz (25kg - 200kg).");
                    return false;
                }
                answers.general.age = age;
                answers.general.height = height;
                answers.general.weight = weight;
            }
            return true;
        }

        function showError(msg) {
            const container = document.getElementById('validation-alert');
            const label = document.getElementById('validation-msg');
            label.textContent = msg;
            container.classList.remove('hidden');
            window.scrollTo({ top: container.offsetTop - 80, behavior: 'smooth' });
        }

        function moveNext() {
            if (validateCurrentStep()) {
                if (currentStep < totalSteps - 1) {
                    goToStep(currentStep + 1);
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                } else {
                    // Trigger Expert Analysis Generator
                    generateAnalysisResults();
                }
            }
        }

        function movePrev() {
            if (currentStep > 0) {
                goToStep(currentStep - 1);
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

