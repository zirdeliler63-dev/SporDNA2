        // OUTPUTS PERSISTENCE ENGINES
        function triggerSaveToHistory() {
            if (!generatedResult) return;
            
            const timestamp = new Date().toLocaleString("tr-TR");
            const freshLog = {
                id: Date.now(),
                timestamp: timestamp,
                answers: JSON.parse(JSON.stringify(answers)),
                recommendedSport: generatedResult.developmentProgram.sportName,
                matchRate: generatedResult.recommendedSports[0] ? generatedResult.recommendedSports[0].matchScore : 90
            };

            // Prevent duplicating identical subsequent clicks
            if (historyLogs.length > 0 && historyLogs[0].recommendedSport === freshLog.recommendedSport && historyLogs[0].answers.general.height === freshLog.answers.general.height && historyLogs[0].answers.general.weight === freshLog.answers.general.weight) {
                return; 
            }

            historyLogs.unshift(freshLog);
            saveHistoryToStorage();
        }

