                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            transition: background-color 0.3s, color 0.3s;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @media print {
            .no-print {
                display: none !important;
            }
            .print-card {
                border: none !important;
                box-shadow: none !important;
                padding: 0 !important;
            }
        }
    </style>
</head>
<body class="bg-gray-50 text-slate-900 dark:bg-slate-950 dark:text-slate-100 flex flex-col min-h-screen transition-colors duration-300 selection:bg-emerald-500 selection:text-white">

    <!-- 1. TOP HEADER BANNER: ATATÜRK QUOTE & SIGNATURE -->
    <div class="bg-gradient-to-r from-slate-900 via-zinc-900 to-slate-900 text-white py-3 px-6 text-center flex flex-col items-center justify-center relative shadow-md border-b border-rose-500/30 no-print">
        <span class="text-[9px] font-black tracking-widest text-rose-500/90 block mb-0.5 uppercase">Ulu Önder M. Kemal Atatürk Anısına</span>
        <h2 class="text-xs md:text-sm lg:text-base font-extrabold text-slate-100 tracking-widest leading-none uppercase select-none">
            "SAĞLAM KAFA SAĞLAM VÜCUTTA BULUNUR."
        </h2>
        <div class="mt-1 flex justify-center">
            <!-- Authentic Vector Atatürk Signature -->
            <svg
              viewBox="0 0 450 120"
              class="w-28 md:w-32 h-auto text-white fill-none opacity-90 filter drop-shadow-[0_2px_4px_rgba(0,0,0,0.6)] brightness-200"
              style="stroke: white; stroke-width: 3.5; stroke-linecap: round; stroke-linejoin: round;"
            >
              <path d="M 50 70 C 55 58, 62 45, 75 35 C 88 25, 105 18, 120 28 C 130 35, 132 50, 120 62 C 105 75, 80 85, 62 82 C 45 80, 42 65, 55 52 C 68 38, 92 25, 115 45" />
              <path d="M 125 50 Q 140 38, 150 48 T 160 62" />
              <path d="M 162 60 Q 170 42, 178 50 T 188 64" />
              <path d="M 190 62 Q 198 45, 204 52 T 212 66" />
              <path d="M 215 65 C 228 50, 248 10, 255 18 C 262 25, 250 65, 242 85 C 235 105, 215 110, 225 90 C 235 70, 260 20, 280 25 C 295 30, 288 70, 276 92 C 265 112, 255 115, 270 95 C 285 75, 310 38, 332 48 C 345 54, 335 88, 315 98 C 295 108, 330 92, 355 80" stroke-width="4" />
              <circle cx="370" cy="72" r="3" fill="currentColor" stroke="none" />
              <path d="M 382 78 C 392 72, 405 60, 412 80" />
              <path d="M 70 96 Q 160 102, 290 98 Q 360 95, 410 88" stroke-width="2.5" />
            </svg>
        </div>
    </div>

    <!-- MAIN APP WRAPPER LAYOUT -->
    <div class="flex-1 flex flex-col lg:flex-row">

        <!-- 2. SOL DİKEY MENÜ SIDEBAR -->
        <aside class="w-full lg:w-72 shrink-0 bg-white dark:bg-slate-900 border-b lg:border-b-0 lg:border-r border-gray-150 dark:border-slate-800 flex flex-col justify-between p-6 z-40 transition-colors duration-300 no-print">
            <div class="space-y-6">
                <!-- Logo Branded Block -->
                <div class="flex items-center gap-3 pb-6 border-b border-gray-150 dark:border-slate-800">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-emerald-500 via-teal-500 to-indigo-600 flex items-center justify-center shadow-md select-none">
                        <i data-lucide="trophy" class="w-5 h-5 text-white"></i>
                    </div>
                    <div>
                        <h1 class="text-lg font-black tracking-tight leading-none bg-gradient-to-r from-emerald-500 via-teal-500 to-indigo-500 bg-clip-text text-transparent">
                            SporDNA
                        </h1>
                        <p class="text-[9px] text-gray-400 dark:text-slate-400 leading-none mt-1 font-mono tracking-widest uppercase">
                            BİYOMEKANİK LABORATUVAR
                        </p>
                    </div>
                </div>

                <!-- Vertical Menu Navigation List -->
                <nav class="space-y-1">
                    <button id="nav-analiz" onclick="switchPage('analiz')" class="nav-btn w-full text-left p-3 rounded-2xl flex items-start gap-3.5 transition-all outline-none cursor-pointer group bg-slate-900 text-white dark:bg-emerald-500 dark:text-slate-950 font-bold shadow-xs">
                        <i data-lucide="activity" class="w-5 h-5 shrink-0 mt-0.5"></i>
                        <div class="leading-snug">
                            <span class="text-xs font-bold block">Fiziksel Analiz</span>
                            <span class="text-[9px] block text-slate-350 dark:text-slate-900">Spor dalı ve gelişim programı</span>
                        </div>
                    </button>
                    <button id="nav-team" onclick="switchPage('team')" class="nav-btn w-full text-left p-3 rounded-2xl flex items-start gap-3.5 transition-all outline-none cursor-pointer group text-slate-600 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
                        <i data-lucide="users" class="w-5 h-5 shrink-0 mt-0.5"></i>
                        <div class="leading-snug">
                            <span class="text-xs font-bold block">Takım Üyeleri</span>
                            <span class="text-[9px] block text-gray-400 dark:text-slate-500">Proje geliştirici rolleri</span>
                        </div>
                    </button>
                    <button id="nav-report" onclick="switchPage('report')" class="nav-btn w-full text-left p-3 rounded-2xl flex items-start gap-3.5 transition-all outline-none cursor-pointer group text-slate-600 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
                        <i data-lucide="file-text" class="w-5 h-5 shrink-0 mt-0.5"></i>
                        <div class="leading-snug">
                            <span class="text-xs font-bold block">Bilimsel Rapor</span>
                            <span class="text-[9px] block text-gray-400 dark:text-slate-500">Uluslararası analiz temeli</span>
                        </div>
                    </button>
                    <button id="nav-presentation" onclick="switchPage('presentation')" class="nav-btn w-full text-left p-3 rounded-2xl flex items-start gap-3.5 transition-all outline-none cursor-pointer group text-slate-600 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
                        <i data-lucide="presentation" class="w-5 h-5 shrink-0 mt-0.5"></i>
                        <div class="leading-snug">
                            <span class="text-xs font-bold block">Proje Sunumu</span>
                            <span class="text-[9px] block text-gray-400 dark:text-slate-500">İnteraktif yatırımcı slaytları</span>
                        </div>
                    </button>
                    <button id="nav-outputs" onclick="switchPage('outputs')" class="nav-btn w-full text-left p-3 rounded-2xl flex items-start gap-3.5 transition-all outline-none cursor-pointer group text-slate-600 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
                        <i data-lucide="share-2" class="w-5 h-5 shrink-0 mt-0.5"></i>
                        <div class="leading-snug">
                            <span class="text-xs font-bold block">Tüm Çıktılar & Arşiv</span>
                            <span class="text-[9px] block text-gray-400 dark:text-slate-500">Analizler ve paylaşım kabini</span>
                        </div>
                    </button>
                </nav>
            </div>

            <!-- Dynamic Ayarlar Settings: Dark Mode Toggle -->
            <div class="pt-6 border-t border-gray-150 dark:border-slate-800 space-y-4">
                <div>
                    <span class="text-[9px] text-gray-400 dark:text-slate-500 font-bold tracking-widest block uppercase font-mono mb-2">UYGULAMA AYARLARI</span>
                    <div class="grid grid-cols-2 gap-2 bg-slate-100 dark:bg-slate-950 p-1 rounded-xl">
                        <button type="button" id="btn-theme-light" onclick="setTheme(false)" class="py-1.5 text-[10px] font-bold rounded-lg flex items-center justify-center gap-1.5 transition-all outline-none cursor-pointer bg-white text-slate-900 shadow-3xs">
                            <i data-lucide="sun" class="w-3.5 h-3.5"></i> Aydınlık
                        </button>
                        <button type="button" id="btn-theme-dark" onclick="setTheme(true)" class="py-1.5 text-[10px] font-bold rounded-lg flex items-center justify-center gap-1.5 transition-all outline-none cursor-pointer text-gray-500 hover:text-slate-800 dark:hover:text-slate-200">
                            <i data-lucide="moon" class="w-3.5 h-3.5"></i> Koyu Mod
                        </button>
                    </div>
                </div>
                <div class="text-center">
                    <span class="text-[9px] text-gray-405 dark:text-slate-500 font-mono block">Model: Gemini 3.5 Flash • v1.4.0</span>
                </div>
            </div>
        </aside>

        <!-- 3. CENTER DYNAMIC DOCK SYSTEM -->
        <main class="flex-1 p-4 md:p-8 overflow-y-auto w-full transition-colors duration-300">

            <!-- PAGE CONTEXT BREADCRUMBS Header -->
            <div class="mb-6 flex flex-col md:flex-row items-start md:items-center justify-between border-b border-gray-150 dark:border-slate-800 pb-4 gap-4">
                <div>
                    <nav class="text-[10px] font-mono font-bold tracking-wider uppercase mb-1 flex items-center gap-1.5 text-emerald-500 dark:text-emerald-400">
                        <span>SPORDNA</span>
                        <i data-lucide="chevron-right" class="w-3 h-3 text-gray-405"></i>
                        <span id="breadcrumb-title" class="text-gray-400 dark:text-slate-400">BİYOMEKANİK KİNESİYOLOJİ LABORATUVARI</span>
                    </nav>
                    <h2 id="view-header-title" class="text-xl md:text-2xl font-black text-slate-900 dark:text-white tracking-tight">
                        Fiziksel Parametrelerinizi Tanımlayın
                    </h2>
                </div>

                <div class="bg-white dark:bg-slate-900 border border-slate-150 dark:border-slate-800 rounded-xl px-4 py-2 shrink-0 flex items-center gap-2.5 shadow-3xs">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                    </span>
                    <span id="lbl-history-counter" class="text-[11px] font-mono font-bold text-slate-700 dark:text-slate-300">0 Başarılı Tarama Saklı</span>
                </div>
            </div>

            <!-- TAB PAGE A: ANALiZ PAGE (Wizard questions or results dashboard) -->
            <div id="page-analiz" class="app-page space-y-8 animate-fade-in">

                <!-- INITIAL MARKETING BAR -->
                <div id="intro-card" class="p-6 bg-white dark:bg-slate-900 border border-gray-150 dark:border-slate-800 rounded-3xl flex flex-col md:flex-row items-start md:items-center justify-between gap-6 no-print shadow-3xs">
                    <div class="max-w-2xl">
                        <h2 class="text-lg md:text-xl font-black text-slate-900 dark:text-white tracking-tight leading-snug">
                             Fiziksel Özelliklerinize %100 Uyan Spor Branşını Tespit Edin
                        </h2>
                        <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed mt-1">
                            Bu sistem iskelet yapınızı (omuz/kalça oranı), duruş sapmalarını (kifoz, lordoz, asimetriler), kas lifi yapınızı ve eklem mobilitenizi sentezleyerek size yön vermeyi amaçlar. Formu doldurarak veya örnek atlet profillerini kullanarak test edebilirsiniz.
                        </p>
                    </div>

                    <div class="bg-slate-50 dark:bg-slate-950 border border-slate-100 dark:border-slate-800 rounded-2xl p-4 shrink-0 flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center">
                            <i data-lucide="activity" class="w-4 h-4 text-emerald-600 dark:text-emerald-400 animate-pulse"></i>
                        </div>
                        <div>
                            <div class="text-xs font-bold text-slate-800 dark:text-slate-200">Doğru Yönlendirme</div>
                            <div class="text-[10px] text-gray-400 dark:text-slate-550 leading-none mt-0.5">Momentum & Biyomekanik katsayı tespiti</div>
                        </div>
                    </div>
                </div>

                <!-- MAIN GRID: FORM OR RESULTS -->
                <div id="app-workspace" class="grid grid-cols-1 lg:grid-cols-4 gap-8">
                    
                    <!-- LEFT WIZARD BOX -->
                    <div id="form-container" class="lg:col-span-3 bg-white dark:bg-slate-900 border border-gray-150 dark:border-slate-800 rounded-3xl p-6 md:p-8 shadow-sm no-print">
                        
                        <!-- Stepper Progress bar -->
                        <div class="relative mb-8">
                            <div class="flex justify-between items-center relative z-10">
                                <!-- Step 1 -->
                                <div class="flex flex-col items-center cursor-pointer step-indicator" onclick="goToStep(0)">
                                    <div id="step-badge-0" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xs border transition-all duration-300 bg-slate-900 border-slate-900 text-white dark:bg-slate-850 dark:border-slate-800 shadow-md ring-4 ring-slate-100 dark:ring-slate-900">1</div>
                                    <span id="step-text-0" class="text-[10px] sm:text-[11px] font-bold text-slate-900 dark:text-slate-100 mt-2">Genel Bilgiler</span>
                                </div>
                                <!-- Step 2 -->
                                <div class="flex flex-col items-center cursor-pointer step-indicator" onclick="goToStep(1)">
                                    <div id="step-badge-1" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xs border transition-all duration-300 bg-white border-gray-200 text-gray-400 dark:bg-slate-900 dark:border-slate-800">2</div>
                                    <span id="step-text-1" class="text-[10px] sm:text-[11px] font-medium text-gray-400 mt-2">İskelet Yapısı</span>
                                </div>
                                <!-- Step 3 -->
                                <div class="flex flex-col items-center cursor-pointer step-indicator" onclick="goToStep(2)">
                                    <div id="step-badge-2" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xs border transition-all duration-300 bg-white border-gray-200 text-gray-400 dark:bg-slate-900 dark:border-slate-800">3</div>
                                    <span id="step-text-2" class="text-[10px] sm:text-[11px] font-medium text-gray-400 mt-2">Duruş (Postür)</span>
                                </div>
                                <!-- Step 4 -->
                                <div class="flex flex-col items-center cursor-pointer step-indicator" onclick="goToStep(3)">
                                    <div id="step-badge-3" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xs border transition-all duration-300 bg-white border-gray-200 text-gray-400 dark:bg-slate-900 dark:border-slate-800">4</div>
                                    <span id="step-text-3" class="text-[10px] sm:text-[11px] font-medium text-gray-400 mt-2">Kas & Lif Tipi</span>
                                </div>
                                <!-- Step 5 -->
                                <div class="flex flex-col items-center cursor-pointer step-indicator" onclick="goToStep(4)">
                                    <div id="step-badge-4" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xs border transition-all duration-300 bg-white border-gray-200 text-gray-400 dark:bg-slate-900 dark:border-slate-800">5</div>
                                    <span id="step-text-4" class="text-[10px] sm:text-[11px] font-medium text-gray-400 mt-2">Kemik & Hedef</span>
                                </div>
                    </div>
                    <!-- Indicator line line -->
                    <div class="absolute top-[18px] left-[6%] right-[6%] h-[2px] bg-slate-100 -z-10">
                        <div id="stepper-line" class="h-full bg-emerald-500 transition-all duration-500 w-0"></div>
                    </div>
                </div>

                <!-- Validation Warning Alert -->
                <div id="validation-alert" class="hidden mb-6 p-4 bg-red-50 border-l-4 border-red-500 rounded-xl flex items-center gap-3 text-red-700 text-xs font-medium">
                    <i data-lucide="alert-circle" class="w-5 h-5 text-red-500 shrink-0"></i>
                    <span id="validation-msg">Lütfen eksik alanları doldurunuz.</span>
                </div>

                <!-- FORM CONTENT SECTIONS -->
                <form id="kinesiology-form" class="min-h-[290px]">
                    
                    <!-- STEP 0: GENERAL SYSTEM INPUTS -->
                    <div id="form-step-0" class="step-pane space-y-6">
                        <div class="border-b border-gray-100 pb-2">
                            <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
                                <i data-lucide="user" class="w-5 h-5 text-emerald-500"></i> Temel Fiziksel Parametreler
                            </h3>
                            <p class="text-[11px] text-slate-500">
                                Genel antropometrik yapınızı girin. Bu değerler mekanik direnç hesabı için temel teşkil eder.
                            </p>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Yaş (Yıl)</label>
                                <input type="number" id="input-age" value="24" min="5" max="100" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-slate-800 outline-none text-sm bg-slate-50/50" />
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Boy (cm)</label>
                                <input type="number" id="input-height" value="180" min="100" max="230" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-slate-800 outline-none text-sm bg-slate-50/50" />
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2">Kilo (kg)</label>
                                <input type="number" id="input-weight" value="75" min="25" max="200" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-slate-800 outline-none text-sm bg-slate-50/50" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-3">Biyolojik Cinsiyet</label>
                            <div class="grid grid-cols-3 gap-3">
                                <button type="button" onclick="setGender('Erkek')" id="btn-gender-Erkek" class="gender-btn px-4 py-3 border text-xs font-semibold rounded-xl text-center transition-all bg-slate-900 border-slate-900 text-white shadow-xs">Erkek</button>
                                <button type="button" onclick="setGender('Kadın')" id="btn-gender-Kadın" class="gender-btn px-4 py-3 border text-xs font-semibold rounded-xl text-center transition-all bg-white border-gray-200 text-gray-700 hover:bg-slate-50">Kadın</button>
                                <button type="button" onclick="setGender('Belirtmek İstemiyorum')" id="btn-gender-Belirtmek İstemiyorum" class="gender-btn px-4 py-3 border text-xs font-semibold rounded-xl text-center transition-all bg-white border-gray-200 text-gray-700 hover:bg-slate-50">Belirtmek İstemiyorum</button>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-3">Güncel Spor Seviyesi</label>
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                                <button type="button" onclick="setFitness('Başlangıç')" id="btn-fit-Başlangıç" class="fit-btn p-4 border text-left rounded-2xl transition-all flex flex-col gap-1 bg-white border-gray-200 hover:bg-slate-50/50">
                                    <span class="text-xs font-bold text-slate-800">Başlangıç Seviyesi</span>
                                    <span class="text-[10px] text-gray-500 leading-snug">Haftada en fazla 1 gün veya hiç spor yapmıyor.</span>
                                </button>
                                <button type="button" onclick="setFitness('Orta')" id="btn-fit-Orta" class="fit-btn p-4 border text-left rounded-2xl transition-all flex flex-col gap-1 border-emerald-500 bg-emerald-50/25 ring-1 ring-emerald-500">
                                    <span class="text-xs font-bold text-emerald-700">Orta Seviye</span>
                                    <span class="text-[10px] text-gray-500 leading-snug">Haftada 2-3 gün düzenli egzersiz veya rekreasyonel spor geçmişi.</span>
                                </button>
                                <button type="button" onclick="setFitness('İleri')" id="btn-fit-İleri" class="fit-btn p-4 border text-left rounded-2xl transition-all flex flex-col gap-1 bg-white border-gray-200 hover:bg-slate-50/50">
                                    <span class="text-xs font-bold text-slate-800">İleri / Profesyonel</span>
                                    <span class="text-[10px] text-gray-500 leading-snug">Haftada 4 günden fazla direnç ve kondisyon çalışan lisanslı sporcu.</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- STEP 1: SKELETAL INPUTS -->
                    <div id="form-step-1" class="step-pane hidden space-y-6">
                        <div class="border-b border-gray-100 pb-2">
                            <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
                                <i data-lucide="compass" class="w-5 h-5 text-emerald-500"></i> İskelet Yapısı & Kemik Çatısı
                            </h3>
                            <p class="text-[11px] text-slate-500">
                                Omuz-kalça oranları ve ekstremite uzunlukları, kuvvet momentini ve spor biyomekaniğini doğrudan etkiler.
                            </p>
                        </div>

                        <div class="space-y-5">
                            <div>
                                <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 uppercase tracking-wider mb-2">Omuz Genişliği</label>
                                <div class="grid grid-cols-3 gap-3">
